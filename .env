# ──────────────────────────────────────────────────────────────
# Notification mode
#   true  → WebSocket realtime (STOMP via SockJS)
#   false → REST polling mỗi 60 giây (legacy, mặc định)
# ──────────────────────────────────────────────────────────────
VITE_USE_WEBSOCKET=false

# WebSocket / API base URL
VITE_WS_URL=http://localhost:8080
